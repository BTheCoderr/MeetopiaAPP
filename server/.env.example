# Signaling server (Render)

PORT=3003
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# Durable reports (Supabase — recommended for App Store / external TestFlight)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Report email alerts (Resend)
REPORT_NOTIFY_EMAIL=you@example.com
RESEND_API_KEY=re_...
REPORT_FROM_EMAIL=reports@yourdomain.com

# Protect GET /admin/reports
REPORT_ADMIN_TOKEN=change-me-long-random
