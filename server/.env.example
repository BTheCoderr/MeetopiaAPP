# Signaling server (Render)

PORT=3003
NODE_ENV=development
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3003

# Durable reports (Supabase — required for App Store / external TestFlight)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Optional: email alerts via Resend (skip for now — check Supabase dashboard instead)
# REPORT_NOTIFY_EMAIL=you@example.com
# RESEND_API_KEY=re_...
# REPORT_FROM_EMAIL=Meetopia Reports <onboarding@resend.dev>

# Protect GET /admin/reports (optional)
REPORT_ADMIN_TOKEN=change-me-long-random
